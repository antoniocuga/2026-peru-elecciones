{
  "name": "elecciones2026",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "generate:2026": "node scripts/generate-2026-results.js",
    "export:distritos": "python3 ../crawler/2026/export_frontend_data.py",
    "generate:senado": "node scripts/generate-senado-sample.js",
    "fetch:senado": "python3 ../crawler/2026/fetch_senado_onpe.py",
    "fetch:senado:sync": "python3 ../crawler/2026/fetch_senado_onpe.py --ftp-sync",
    "fetch:congreso": "python3 ../crawler/2026/fetch_congreso_onpe.py",
    "fetch:congreso:sync": "python3 ../crawler/2026/fetch_congreso_onpe.py --ftp-sync",
    "fetch:extranjero": "python3 ../crawler/2026/fetch_extranjero_paises.py --out public/data-primera-vuelta/extranjero_paises.json",
    "fetch:extranjero:sync": "python3 ../crawler/2026/fetch_extranjero_paises.py --out public/data-primera-vuelta/extranjero_paises.json --ftp-sync",
    "sim:parlamento": "ONPE_SSL_VERIFY=0 python3 ../crawler/2026/fetch_senado_onpe.py --fuente distrito-unico --circuits-json ../crawler/2026/senado_circuits.json --out public/data-primera-vuelta/senado_total.json --ftp-sync && ONPE_SSL_VERIFY=0 python3 ../crawler/2026/fetch_congreso_onpe.py --ftp-sync",
    "loop:parlamento-extranjero": "while true; do npm run sim:parlamento || true; npm run fetch:extranjero:sync || true; sleep 60; done",
    "crawl:senado": "cd ../crawler/2026 && ONPE_SSL_VERIFY=0 python3 -m scrapy crawl senado2026",
    "sim:parlamento-presidencial": "python3 ../crawler/2026/parlamento_desde_presidencial.py --write",
    "split:lima": "python3 ../crawler/2026/split_lima_json.py",
    "lint": "eslint . --ext .vue,.js,.jsx,.cjs,.mjs --fix"
  },
  "dependencies": {
    "@popperjs/core": "^2.11.8",
    "axios": "^1.7.7",
    "bootstrap": "^5.3.3",
    "bootstrap-vue-3": "^0.20.2",
    "core-js": "^3.36.1",
    "d3": "^7.9.0",
    "d3-geo": "^3.1.0",
    "d3-parliament-chart": "^0.0.3",
    "lodash": "^4.17.21",
    "numeral": "^2.0.6",
    "pinia": "^2.2.4",
    "sass": "^1.77.8",
    "topojson": "^3.0.2",
    "vue": "^3.5.11",
    "vue-carousel": "^0.18.0",
    "vue-router": "^4.4.5"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.1.4",
    "eslint": "^8.57.0",
    "eslint-plugin-vue": "^9.27.0",
    "sass-embedded": "^1.97.3",
    "vite": "^5.4.8",
    "vue-eslint-parser": "^9.4.3"
  },
  "browserslist": [
    "> 1%",
    "last 2 versions",
    "not dead"
  ],
  "resolutions": {
    "node-sass": "npm:sass@^1.77.8"
  }
}
